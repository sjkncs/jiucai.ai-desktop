# 久财AI 环境配置示例
# JiuCai AI Environment Configuration Example

# ============================================
# API 配置 / API Configuration
# ============================================

# 后端 API 基础 URL
API_BASE_URL=http://localhost:3000

# AkShare 数据服务 URL
AKSHARE_API_URL=http://localhost:8001

# BaoStock 数据服务 URL
BAOSTOCK_API_URL=http://localhost:8002

# ============================================
# AI 服务配置 / AI Service Configuration
# ============================================

# OpenAI API Key (如果使用)
# OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI API Base URL (可选，用于代理)
# OPENAI_API_BASE=https://api.openai.com/v1

# AI 模型名称
# AI_MODEL=gpt-3.5-turbo

# ============================================
# 数据库配置 / Database Configuration
# ============================================

# 数据存储路径
DATA_PATH=./data

# LowDB 数据库文件路径
DB_FILE=./server/data/db.json

# ============================================
# 应用配置 / Application Configuration
# ============================================

# 应用端口
PORT=3000

# 前端开发服务器端口
FRONTEND_PORT=5173

# API 服务器端口
API_PORT=3000

# 环境模式 (development / production)
NODE_ENV=development

# ============================================
# 日志配置 / Logging Configuration
# ============================================

# 日志级别 (debug / info / warn / error)
LOG_LEVEL=info

# 日志文件路径
LOG_PATH=./logs

# ============================================
# 安全配置 / Security Configuration
# ============================================

# CORS 允许的源
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Session 密钥 (请修改为随机字符串)
SESSION_SECRET=your-secret-key-here-change-me

# JWT 密钥 (如果使用)
# JWT_SECRET=your-jwt-secret-here

# ============================================
# 第三方服务配置 / Third-party Services
# ============================================

# 东方财富 API (如果需要)
# EASTMONEY_API_KEY=your-eastmoney-api-key

# 其他数据源配置
# TUSHARE_TOKEN=your-tushare-token

# ============================================
# 桌面应用配置 / Desktop App Configuration
# ============================================

# 自动更新服务器 URL (可选)
# UPDATE_SERVER_URL=https://your-update-server.com

# 应用版本
APP_VERSION=2.0.0

# ============================================
# 开发配置 / Development Configuration
# ============================================

# 是否启用热重载
HOT_RELOAD=true

# 是否打开开发者工具
OPEN_DEVTOOLS=false

# ============================================
# 使用说明 / Usage Instructions
# ============================================

# 1. 复制此文件为 .env
#    cp .env.example .env
#
# 2. 根据实际情况修改配置值
#
# 3. 不同环境可创建不同的配置文件:
#    - .env.development  (开发环境)
#    - .env.production   (生产环境)
#    - .env.test         (测试环境)
#
# 4. 配置文件已被 .gitignore 忽略，不会被提交到 Git
#
# 5. 敏感信息（如 API Key）请妥善保管，不要分享给他人
