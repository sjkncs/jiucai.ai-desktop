# 久财AI 桌面应用配置
# JiuCai AI Desktop App Configuration

# API 配置
API_BASE_URL=http://localhost:3000
AKSHARE_API_URL=http://localhost:8001
BAOSTOCK_API_URL=http://localhost:8002

# AI 服务配置 (可选)
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_API_BASE=https://api.openai.com/v1
# AI_MODEL=gpt-3.5-turbo

# 应用配置
APP_VERSION=2.0.0
NODE_ENV=development

# 开发配置
OPEN_DEVTOOLS=false
HOT_RELOAD=true

# 更新服务器 (可选)
# UPDATE_SERVER_URL=https://your-update-server.com
